{
  "version": "1.9.5",
  "name": "Mobile Dashboard Upgrade",

  "files": {

    "docs/index.html": {
      "mode": "system",
      "content": "<!DOCTYPE html><html><head><title>BudE StoryBoard AI</title><meta name='viewport' content='width=device-width, initial-scale=1.0'><link rel='stylesheet' href='styles.css'></head><body><header><h1>🤖 BudE</h1><p>StoryBoard AI Studio</p></header><main><div class='status'>🟢 Creative Engine Ready</div><div class='grid'><a href='generator.html' class='card'>✍️ Create Story</a><div class='card'>👤 Character Studio</div><div class='card'>🌎 World Builder</div><div class='card'>🎬 Storyboard</div><div class='card'>🎨 Art Studio</div><div class='card'>🤖 AI Director</div></div></main><nav><span>🏠</span><span>✍️</span><span>📁</span><span>⚙️</span></nav></body></html>"
    },


    "docs/generator.html": {
      "mode": "system",
      "content": "<!DOCTYPE html><html><head><title>BudE Generator</title><meta name='viewport' content='width=device-width, initial-scale=1.0'><link rel='stylesheet' href='styles.css'></head><body><header><h1>✍️ Create With BudE</h1></header><main><label>Idea</label><textarea id='prompt' placeholder='Describe your story, character, or world...'></textarea><label>Creation Type</label><select id='type'><option>Story</option><option>Character</option><option>World</option><option>Comic</option><option>Movie</option></select><label>Style</label><select id='style'><option>Anime</option><option>Fantasy</option><option>Sci-Fi</option><option>Comic</option><option>Realistic</option></select><button onclick='generate()'>GENERATE</button><section class='output'><h2>Output</h2><pre id='output'>Waiting...</pre></section></main><nav><span>🏠</span><span>✍️</span><span>📁</span><span>⚙️</span></nav><script src='generator.js'></script></body></html>"
    },


    "docs/styles.css": {
      "mode": "system",
      "content": "*{box-sizing:border-box}body{margin:0;background:#08111f;color:white;font-family:Arial,sans-serif;padding-bottom:70px}header{text-align:center;padding:20px;background:#111d32}main{padding:15px}.status,.card,.output{background:#16253b;border-radius:16px;padding:20px;margin:15px 0}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.card{text-decoration:none;color:white;text-align:center;font-size:18px;min-height:90px;display:flex;align-items:center;justify-content:center}textarea,select{width:100%;padding:15px;margin:10px 0;border-radius:12px;font-size:16px}textarea{height:130px}button{width:100%;padding:18px;border:0;border-radius:14px;background:#304f7a;color:white;font-size:20px;margin-top:15px}pre{white-space:pre-wrap}nav{position:fixed;bottom:0;left:0;right:0;background:#111d32;padding:15px;display:flex;justify-content:space-around;font-size:25px}@media(max-width:500px){.grid{grid-template-columns:1fr}}"
    },


    "docs/generator.js": {
      "mode": "system",
      "content": "function generate(){let prompt=document.getElementById('prompt').value;let type=document.getElementById('type').value;let style=document.getElementById('style').value;let output={type:type,style:style,prompt:prompt,status:'BudE received creation request'};localStorage.setItem('bude_request',JSON.stringify(output));document.getElementById('output').textContent=JSON.stringify(output,null,2);}"
    }

  }
}
